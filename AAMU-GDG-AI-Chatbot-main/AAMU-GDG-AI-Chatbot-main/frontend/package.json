{
  "name": "university-chatbot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "kb:build": "node scripts/build-knowledge-base.mjs",
    "kb:evaluate": "tsx scripts/evaluate-knowledge-base.ts",
    "predev": "npm run kb:build",
    "dev": "vite",
    "prebuild": "npm run kb:build && npm run kb:evaluate",
    "build": "vite build",
    "lint": "eslint src scripts vite.config.ts vitest.config.ts",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "framer-motion": "^11.1.12",
    "lucide-react": "^0.344.0",
    "pdfjs-dist": "^5.1.91",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.18",
    "caniuse-lite": "^1.0.30001806",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.23.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.3.3",
    "vitest": "^4.1.10"
  }
}
